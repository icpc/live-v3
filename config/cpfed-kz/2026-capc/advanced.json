        "type": "overrideTeamTemplate",
        "regexes": {
            "fromName": {
                "from": "{team.fullName}",
                "rules": {
                    "(.*) \\(Kazakhstan\\)": {
                        "teamName": "🇰🇿 $1"
                        //"teamName": "$1"
                    },
                    "(.*) \\(Uzbekistan\\)": {
                        "teamName": "🇺🇿 $1"
